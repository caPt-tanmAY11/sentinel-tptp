# =============================================================================
# SENTINEL V2 — .gitignore
# =============================================================================

# =============================================================================
# PYTHON
# =============================================================================

# Byte-compiled / optimised
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyc

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/
htmlcov/

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# Jupyter
.ipynb_checkpoints
*.ipynb

# pyenv
.python-version

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre
.pyre/

# pytype
.pytype/

# Cython
cython_debug/

# =============================================================================
# ENVIRONMENT & SECRETS
# =============================================================================

# Local environment — NEVER commit credentials
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
*.env

# Keep the example file in version control
!.env.example

# =============================================================================
# ML MODELS & ARTIFACTS
# =============================================================================

# Trained model files — large binary, regenerated by --step train
ml_models/saved_models/*.txt
ml_models/saved_models/*.joblib
ml_models/saved_models/*.pkl
ml_models/saved_models/*.pt
ml_models/saved_models/*.pth
ml_models/saved_models/*.bin
ml_models/saved_models/*.onnx

# Keep the directory and meta JSON in version control
!ml_models/saved_models/.gitkeep
!ml_models/saved_models/lgbm_meta.json

# SHAP explainer cache
shap_cache/
*.shap

# MLflow experiment tracking
mlruns/
mlartifacts/

# Feature weights — regenerated by training, but keep stub
# (the stub is already in config/feature_weights.json with empty weights)

# =============================================================================
# DATA FILES
# =============================================================================

# Generated datasets — large, regenerated by --step seed
data/
*.parquet
*.csv
*.tsv
*.feather
*.arrow

# But keep schema/example files if any
!data/.gitkeep

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL local data volumes (Docker)
postgres_data/

# SQLite (if used for local testing)
*.db
*.sqlite
*.sqlite3

# Database dumps
*.sql.gz
*.dump

# =============================================================================
# DOCKER & INFRASTRUCTURE
# =============================================================================

# Docker volumes (bind-mount local data)
redis_data/
kafka_data/

# Override files for local dev
docker-compose.override.yml
docker-compose.local.yml

# =============================================================================
# LOGS
# =============================================================================

logs/
*.log
*.log.*
log/
sentinel.log
uvicorn.log
gunicorn.log

# =============================================================================
# NODE.JS / NEXT.JS (dashboards/)
# =============================================================================

# Dependencies
dashboards/node_modules/
node_modules/

# Next.js build output
dashboards/.next/
dashboards/out/
.next/
out/

# Production build
dashboards/build/

# Vercel
.vercel

# TypeScript build info
*.tsbuildinfo
dashboards/next-env.d.ts

# Local env for dashboard
dashboards/.env.local
dashboards/.env.development.local
dashboards/.env.test.local
dashboards/.env.production.local

# npm / yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Keep package.json but not the lock file
!dashboards/package.json

# =============================================================================
# IDE & EDITORS
# =============================================================================

# VSCode
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# PyCharm / JetBrains
.idea/
*.iml
*.iws
*.ipr
.idea_modules/

# Vim
*.swp
*.swo
*~
.netrwhist

# Emacs
*#
.#*
\#*#

# Sublime Text
*.sublime-project
*.sublime-workspace

# Spyder
.spyderproject.db
.spyproject

# Rope
.ropeproject

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptionKey
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
.fuse_hidden*
.directory
.Trash-*
.nfs*

# =============================================================================
# TESTING & COVERAGE
# =============================================================================

# Test output
.pytest_cache/
test-results/
test_output/
junit.xml
coverage/
.coverage
coverage.xml
htmlcov/

# Hypothesis
.hypothesis/

# =============================================================================
# MONITORING & PROFILING
# =============================================================================

# cProfile output
*.prof
*.lprof

# Memory profiler
mprofile_*.dat

# Prometheus local data
prometheus_data/

# =============================================================================
# TEMPORARY & MISC
# =============================================================================

# Temporary files
tmp/
temp/
.tmp/
*.tmp
*.temp
*.bak
*.orig
*.rej

# OS thumbnail cache
.thumbnails

# Archive files (don't commit generated zips)
*.zip
*.tar.gz
*.tar.bz2
*.tgz
*.rar
*.7z

# Jupyter notebooks (if any stray ones exist)
*.ipynb

# =============================================================================
# KEEP THESE (explicit exceptions)
# =============================================================================

# Keep placeholder files that maintain empty directory structure
!**/.gitkeep

# Keep example/template files
!.env.example
!docker-compose.yml
!requirements.txt

# Keep stub config files
!config/feature_weights.json
!config/intervention_policy.json

# Keep schema SQL
!database/init.sql

# Keep test files
!tests/
!tests/*.py